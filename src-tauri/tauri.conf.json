{
  "productName": "cat-editor",
  "version": "1.0.0",
  "identifier": "com.cat.editor",
  "build": {
    "beforeDevCommand": null,
    "beforeBuildCommand": null,
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "C-at Editor",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "languages": ["English", "Russian"],
        "installerIcon": "icons/icon.ico"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}